# Llama Dashboard Environment Configuration
# Copy this file to .env and update the values

# llama.cpp Server
LLAMACPP_URL=https://ai.aradhel.dev/v1
LLAMACPP_API_KEY=

# Dashboard
DASHBOARD_NAME=Llama Dashboard
REFRESH_INTERVAL=10000
THEME=dark

# GPU Configuration
PRIMARY_GPU=NVIDIA RTX PRO 4000 Blackwell
VRAM=24576
CUDA_VERSION=12.x
LLAMA_VERSION=built-in
DEVICES=[]
